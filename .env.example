# --- API keys ---
# OPENAI_API_KEY serves openai/... and bare model names (native OpenAI).
# OPENROUTER_API_KEY serves openrouter/... model names.
# You only need the keys for the routes you actually use below.
OPENAI_API_KEY=<openai-key>
OPENROUTER_API_KEY=<openrouter-key>

# Optional tool providers
ANTHROPIC_API_KEY=<anthropic-api-key>
EXA_API_KEY=<exa-api-key>
COHERE_API_KEY=<cohere-api-key>

# --- Model routes by role (edit freely) ---
# The model name IS the route; the name alone decides the endpoint:
#   openrouter/<provider>/<model>  -> via OpenRouter, e.g. openrouter/deepseek/deepseek-v4-flash
#   openai/<model>                 -> OpenAI native, e.g. openai/gpt-4o-mini
#   bare names (gpt-4o, o3)        -> OpenAI native (legacy)
# Workers/stakeholder run through LiteLLM and accept any LiteLLM route
# (e.g. anthropic/claude-3-7-sonnet); manager/judge need an OpenAI-compatible
# endpoint, so use openai/... or openrouter/... there.
MANAGER_MODEL_NAME=openai/gpt-4o-mini
WORKER_MODEL_NAME=openai/gpt-4o-mini
STAKEHOLDER_MODEL_NAME=openai/gpt-4o-mini
JUDGE_MODEL_NAME=openai/gpt-4o-mini

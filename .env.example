# --- API keys ---
# Option A (OpenRouter): set BOTH keys below to your OpenRouter key (sk-or-v1-...)
# and keep OPENAI_BASE_URL pointing at OpenRouter. OPENAI_API_KEY feeds the native
# OpenAI client (manager + LLM judges); OPENROUTER_API_KEY feeds the LiteLLM path
# (workers + stakeholder). Model names must then be full OpenRouter slugs.
# Option B (native providers): set real provider keys, remove/comment
# OPENAI_BASE_URL and OPENROUTER_API_KEY, and use bare model names ("gpt-4o").
# Routing policy lives in manager_agent_gym/core/common/model_provider.py.
OPENAI_API_KEY=<openrouter-or-openai-key>
OPENROUTER_API_KEY=<openrouter-key>

# Point the native OpenAI client at OpenRouter's OpenAI-compatible endpoint.
# Leave unset to use OpenAI directly.
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Optional tool providers
ANTHROPIC_API_KEY=<anthropic-api-key>
EXA_API_KEY=<exa-api-key>
COHERE_API_KEY=<cohere-api-key>

# --- Model names by role (edit freely) ---
# With OpenRouter: full slugs, e.g. openai/gpt-4o-mini, anthropic/claude-3.7-sonnet,
# google/gemini-2.0-flash (the worker/stakeholder path adds the "openrouter/" prefix
# automatically). With native providers: bare names, e.g. gpt-4o, claude-3-7-sonnet.
MANAGER_MODEL_NAME=openai/gpt-4o-mini
WORKER_MODEL_NAME=openai/gpt-4o-mini
STAKEHOLDER_MODEL_NAME=openai/gpt-4o-mini
JUDGE_MODEL_NAME=openai/gpt-4o-mini

# Output cap for structured LLM calls that don't set their own (default 4096).
# LLM_DEFAULT_MAX_COMPLETION_TOKENS=4096
